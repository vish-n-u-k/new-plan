{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "architect/environment_config_schema.schema.json",
  "type": "object",
  "required": ["schema", "validation"],
  "properties": {
    "schema": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["type", "required", "description"],
        "properties": {
          "type": { "type": "string" },
          "required": { "type": "boolean" },
          "description": { "type": "string" },
          "sensitive": { "type": "boolean" },
          "variesByEnvironment": { "type": "boolean" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "validation": {
      "type": "object",
      "required": ["requiredInProduction", "sensitiveVars"],
      "properties": {
        "requiredInProduction": { "type": "array", "items": { "type": "string" } },
        "sensitiveVars": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "metadata": { "type": "object", "additionalProperties": true },
    "unknowns": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
  }
}
